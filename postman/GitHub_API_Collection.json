{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "GitHub REST API – Lab Collection",
    "description": "Postman collection for GitHub REST API lab work.\nCovers: Auth check, POST, PATCH, DELETE with test scripts.\n\nAuthor: IusiumbeliSerghei\nDiscipline: Automated Software Testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://api.github.com",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_GITHUB_TOKEN_HERE",
      "type": "string",
      "description": "Paste your GitHub Personal Access Token here (repo + delete_repo scopes)"
    },
    {
      "key": "username",
      "value": "IusiumbeliSerghei",
      "type": "string"
    },
    {
      "key": "repoName",
      "value": "",
      "type": "string",
      "description": "Set automatically after POST request"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "5.1.1 – Check Authorization (GET /user)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TC-POSTMAN-01: Verify status code 200 OK",
              "pm.test('Status code is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// TC-POSTMAN-02: Response body contains 'login' field",
              "pm.test('Response contains login field', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('login');",
              "    pm.expect(jsonData.login).to.eql(pm.collectionVariables.get('username'));",
              "});",
              "",
              "// TC-POSTMAN-03: Response contains 'id' field (positive number)",
              "pm.test('Response contains positive id', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.id).to.be.a('number').and.to.be.above(0);",
              "});",
              "",
              "// TC-POSTMAN-04: Content-Type header contains application/json",
              "pm.test('Content-Type is application/json', function () {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "",
              "// TC-POSTMAN-05: X-RateLimit-Limit header is present",
              "pm.test('X-RateLimit-Limit header is present', function () {",
              "    pm.expect(pm.response.headers.get('X-RateLimit-Limit')).to.exist;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/vnd.github+json"
          },
          {
            "key": "X-GitHub-Api-Version",
            "value": "2022-11-28"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/user",
          "host": ["{{baseUrl}}"],
          "path": ["user"]
        },
        "description": "Verifies that the Bearer Token is valid and returns the authenticated user's data.\n\nEndpoint: GET /user\nExpected: 200 OK"
      }
    },
    {
      "name": "5.1.2 – Create Repository (POST /user/repos)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Generate unique repo name using timestamp",
              "var timestamp = new Date().getTime();",
              "var repoName = 'postman-test-repo-' + timestamp;",
              "pm.collectionVariables.set('repoName', repoName);",
              "console.log('Generated repo name: ' + repoName);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TC-POSTMAN-06: Status code 201 Created",
              "pm.test('Status code is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "// TC-POSTMAN-07: Response body has correct 'name' field",
              "pm.test('Response name matches requested name', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.name).to.eql(pm.collectionVariables.get('repoName'));",
              "});",
              "",
              "// TC-POSTMAN-08: Response body has 'full_name' field",
              "pm.test('Response contains full_name', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('full_name');",
              "    pm.expect(jsonData.full_name).to.include(pm.collectionVariables.get('username'));",
              "});",
              "",
              "// TC-POSTMAN-09: Visibility is public",
              "pm.test('Repository visibility is public', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.visibility).to.eql('public');",
              "    pm.expect(jsonData.private).to.be.false;",
              "});",
              "",
              "// TC-POSTMAN-10: Owner login matches username",
              "pm.test('Owner login matches authenticated user', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.owner.login).to.eql(pm.collectionVariables.get('username'));",
              "});",
              "",
              "// TC-POSTMAN-11: html_url is present",
              "pm.test('html_url is present in response', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('html_url');",
              "    pm.expect(jsonData.html_url).to.be.a('string').and.to.not.be.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/vnd.github+json"
          },
          {
            "key": "X-GitHub-Api-Version",
            "value": "2022-11-28"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{repoName}}\",\n  \"description\": \"Created by Postman – Automated Testing Lab\",\n  \"private\": false,\n  \"auto_init\": false\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/user/repos",
          "host": ["{{baseUrl}}"],
          "path": ["user", "repos"]
        },
        "description": "Creates a new public GitHub repository.\n\nEndpoint: POST /user/repos\nExpected: 201 Created\n\nThe repo name is auto-generated in Pre-request Script and saved as collection variable {{repoName}}."
      }
    },
    {
      "name": "5.1.3 – Update Repository (PATCH /repos/{owner}/{repo})",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TC-POSTMAN-12: Status code 200 OK",
              "pm.test('Status code is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// TC-POSTMAN-13: Description was updated",
              "pm.test('Description was updated correctly', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.description).to.eql('Updated by Postman – Automated Testing Lab');",
              "});",
              "",
              "// TC-POSTMAN-14: Repository name remains unchanged",
              "pm.test('Repository name is unchanged after PATCH', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.name).to.eql(pm.collectionVariables.get('repoName'));",
              "});",
              "",
              "// TC-POSTMAN-15: has_issues is now true",
              "pm.test('has_issues is enabled after PATCH', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.has_issues).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Accept",
            "value": "application/vnd.github+json"
          },
          {
            "key": "X-GitHub-Api-Version",
            "value": "2022-11-28"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"description\": \"Updated by Postman – Automated Testing Lab\",\n  \"has_issues\": true\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/repos/{{username}}/{{repoName}}",
          "host": ["{{baseUrl}}"],
          "path": ["repos", "{{username}}", "{{repoName}}"]
        },
        "description": "Updates the description and has_issues property of the created repository.\n\nEndpoint: PATCH /repos/{owner}/{repo}\nExpected: 200 OK\n\nNote: GitHub REST API uses PATCH for partial updates (not PUT)."
      }
    },
    {
      "name": "5.1.4 – Delete Repository (DELETE /repos/{owner}/{repo})",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TC-POSTMAN-16: Status code 204 No Content",
              "pm.test('Status code is 204 No Content', function () {",
              "    pm.response.to.have.status(204);",
              "});",
              "",
              "// TC-POSTMAN-17: Response body is empty",
              "pm.test('Response body is empty on 204', function () {",
              "    pm.expect(pm.response.text()).to.be.empty;",
              "});",
              "",
              "console.log('Repository deleted: ' + pm.collectionVariables.get('repoName'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Accept",
            "value": "application/vnd.github+json"
          },
          {
            "key": "X-GitHub-Api-Version",
            "value": "2022-11-28"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/repos/{{username}}/{{repoName}}",
          "host": ["{{baseUrl}}"],
          "path": ["repos", "{{username}}", "{{repoName}}"]
        },
        "description": "Deletes the repository created in the POST step.\n\nEndpoint: DELETE /repos/{owner}/{repo}\nExpected: 204 No Content"
      }
    },
    {
      "name": "NEGATIVE – GET deleted repo (404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TC-POSTMAN-18: Deleted repo returns 404",
              "pm.test('Deleted repository returns 404 Not Found', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test('Response body contains Not Found message', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.eql('Not Found');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/vnd.github+json"
          },
          {
            "key": "X-GitHub-Api-Version",
            "value": "2022-11-28"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/repos/{{username}}/{{repoName}}",
          "host": ["{{baseUrl}}"],
          "path": ["repos", "{{username}}", "{{repoName}}"]
        },
        "description": "Verifies that accessing a deleted repository returns 404 Not Found.\n\nEndpoint: GET /repos/{owner}/{repo}\nExpected: 404 Not Found"
      }
    }
  ]
}
